<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17" fx:controller="AuctionSystem.controller.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="HỆ THỐNG QUẢN TRỊ ĐẤU GIÁ" />

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Label fx:id="statusLabel" style="-fx-text-fill: #2ecc71; -fx-font-size: 14px;" text="Trạng thái: Đang kết nối" />
                <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 5 15;" text="Đăng xuất" />
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 15;">
            <VBox spacing="5" VBox.vgrow="SOMETIMES">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Danh sách các phiên đấu giá đang diễn ra" />

                <TableView fx:id="auctionTable" prefHeight="250.0">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="Hiện chưa có phiên đấu giá nào" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                        <TableColumn fx:id="colItemName" prefWidth="180" text="Tên Sản Phẩm" />
                        <TableColumn fx:id="colCurrentBid" prefWidth="120" text="Giá Hiện Tại" />
                        <TableColumn fx:id="colBidder" prefWidth="150" text="Người Dẫn Đầu" />
                        <TableColumn fx:id="colStatus" prefWidth="120" text="Trạng Thái" />
                        <TableColumn fx:id="colTimeLeft" prefWidth="120" text="Thời Gian" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button onAction="#handleView" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Xem Chi Tiết" />
                    <Button onAction="#handleStop" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Dừng Phiên" />
                </HBox>
            </VBox>

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <LineChart fx:id="priceChart" animated="false" title="Biến động giá sản phẩm">
                    <xAxis>
                        <CategoryAxis label="Lượt đấu giá" side="BOTTOM" gapStartAndEnd="false" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Giá trị (VNĐ)" side="LEFT" />
                    </yAxis>
                </LineChart>
            </VBox>
        </VBox>
    </center>
</BorderPane>