<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="AuctionSystem.controller.RoleSelectionController"
      alignment="CENTER" spacing="25" style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="BẠN MUỐN THAM GIA HỆ THỐNG VỚI VAI TRÒ NÀO?"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="30" alignment="CENTER">
        <Button text="BẮT ĐẦU ĐI ĐẤU GIÁ&#10;(Người mua - Bidder)"
                fx:id="btnBuyer" onAction="#handleBuyerMode"
                prefWidth="220" prefHeight="100" alignment="CENTER"
                style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Button text="QUẢN LÝ PHÒNG ĐẤU GIÁ&#10;(Người bán - Seller)"
                fx:id="btnSeller" onAction="#handleSellerMode"
                prefWidth="220" prefHeight="100" alignment="CENTER"
                style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <Button text="Đăng xuất" onAction="#handleLogout"
            style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-underline: true; -fx-cursor: hand;"/>
</VBox>