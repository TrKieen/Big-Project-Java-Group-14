<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="AuctionSystem.controller.RoleSelectionController"
           style="-fx-background-color: linear-gradient(to bottom right, #0b0b1f, #1a103d);">

    <children>

        <!-- Main Card -->
        <VBox alignment="CENTER"
              spacing="35"
              maxWidth="800"
              maxHeight="450"
              style="-fx-background-color: rgba(20,20,20,0.92);
                     -fx-background-radius: 25;
                     -fx-padding: 40;
                     -fx-effect: dropshadow(gaussian, rgba(138,43,226,0.35), 35, 0.2, 0, 8);">

            <Label text="BẠN MUỐN THAM GIA VỚI VAI TRÒ NÀO?"
                   style="-fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>

            <!-- Role buttons -->
            <HBox spacing="30" alignment="CENTER">

                <Button fx:id="btnBuyer"
                        onAction="#handleBuyerMode"
                        prefWidth="280"
                        prefHeight="160"
                        text="🛒&#10;BẮT ĐẦU ĐI ĐẤU GIÁ&#10;(Người mua - Bidder)"
                        wrapText="true"
                        style="-fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-color: linear-gradient(to right, #5f2cff, #7b42ff);
                               -fx-text-fill: white;
                               -fx-background-radius: 20;
                               -fx-cursor: hand;" />

                <Button fx:id="btnSeller"
                        onAction="#handleSellerMode"
                        prefWidth="280"
                        prefHeight="160"
                        text="🏪&#10;QUẢN LÝ PHÒNG ĐẤU GIÁ&#10;(Người bán - Seller)"
                        wrapText="true"
                        style="-fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-color: linear-gradient(to right, #7b42ff, #9a5cff);
                               -fx-text-fill: white;
                               -fx-background-radius: 20;
                               -fx-cursor: hand;" />

            </HBox>

            <Button text="Đăng xuất"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #ff6b6b;
                           -fx-font-size: 14px;
                           -fx-underline: true;
                           -fx-cursor: hand;"/>

        </VBox>

    </children>
</StackPane>