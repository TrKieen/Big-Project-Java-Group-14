<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="AuctionSystem.controller.BidderDashboardController"
      prefHeight="720" prefWidth="1280"
      style="-fx-background-color: #f8fafc; -fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif;">

    <VBox spacing="20" style="-fx-background-color: #0f172a; -fx-padding: 30 20 20 20;" prefWidth="250">
        <VBox spacing="4" alignment="CENTER">
            <Label text="SÀN ĐẤU GIÁ TRỰC TUYẾN" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #38bdf8; -fx-letter-spacing: 1px;"/>
        </VBox>

        <Separator opacity="0.1"/>
        <VBox spacing="8" VBox.vgrow="ALWAYS">
            <Button fx:id="btnMenuAuction" text=" Sảnh Đấu Giá" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: #1e293b; -fx-text-fill: #f8fafc; -fx-font-size: 14px; -fx-padding: 12 15; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button fx:id="btnMenuHistory" text=" Lịch Sử Đặt Giá" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-padding: 12 15; -fx-cursor: hand;" onAction="#handleGoToHistory"/>
        </VBox>

        <Button text="Làm mới kết nối" onAction="#handleRefresh" maxWidth="Infinity"
                style="-fx-background-color: #0284c7; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Separator opacity="0.1"/>
        <Button fx:id="btnLogout" text=" Đăng xuất" onAction="#handleLogout" maxWidth="Infinity" alignment="BASELINE_LEFT"
                style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-size: 14px; -fx-padding: 12 15; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </VBox>

    <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-padding: 25;">

        <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 4);">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Bảng Điều Khiển Đấu Giá" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            </VBox>
            <HBox alignment="CENTER" spacing="10">
                <Label text="Vai trò: Bidder |" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                <Label fx:id="lblUsername" text="Chưa đăng nhập" style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </HBox>
        </HBox>

        <GridPane hgap="20" vgap="20" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints percentWidth="52"/>
                <ColumnConstraints percentWidth="48"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="100"/>
            </rowConstraints>

            <VBox spacing="15" GridPane.columnIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 4);">
                <Label text="Danh Sách Phiên Đấu Giá Trực Tuyến" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <TableView fx:id="itemTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-base: white; -fx-control-inner-background: white; -fx-table-cell-border-color: #f1f5f9; -fx-background-radius: 8;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="45" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colName" text="Tên Sản Phẩm" prefWidth="140"/>
                        <TableColumn fx:id="colPrice" text="Giá Hiện Tại" prefWidth="110" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                        <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="95" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colTime" text="Thời Gian Còn Lại" prefWidth="120" style="-fx-alignment: CENTER;"/>
                    </columns>
                </TableView>
            </VBox>

            <ScrollPane GridPane.columnIndex="1" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-pane-border-color: transparent;">
                <VBox spacing="20">

                    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 4);">
                        <Label text="Chi Tiết Sản Phẩm Đang Chọn" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Separator style="-fx-opacity: 0.4;"/>

                        <GridPane hgap="15" vgap="12">
                            <Label text="Danh mục:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblItemType" text="..." GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #0284c7; -fx-font-weight: bold;"/>

                            <Label text="Tên sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailName" text="Chưa chọn sản phẩm" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;" wrapText="true"/>

                            <Label text="Mô tả chi tiết:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblDetailDesc" text="..." GridPane.columnIndex="1" GridPane.rowIndex="2" wrapText="true" style="-fx-text-fill: #334155; -fx-line-spacing: 3;"/>

                            <Label text="Người dẫn đầu:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblHighestBidder" text="..." GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-text-fill: #1e293b; -fx-font-weight: bold;"/>

                            <Label text="Giá trị hiện tại:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblStartPrice" text="..." GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #10b981;"/>
                        </GridPane>
                    </VBox>

                    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 4);">
                        <Label text="Đặt Giá Tại Đây" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent;">
                            <Tab text="Đặt Giá Thủ Công">
                                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 18 0 5 0;">
                                    <TextField fx:id="txtBidPrice" promptText="Nhập mức giá muốn đặt (VND)..." HBox.hgrow="ALWAYS"
                                               style="-fx-background-radius: 8; -fx-padding: 11; -fx-border-color: #cbd5e1; -fx-background-color: #f8fafc; -fx-font-size: 13px;"/>
                                    <Button fx:id="btnSubmitBid" text="Đặt Giá" onAction="#handleBid" prefHeight="40"
                                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 22; -fx-cursor: hand;"/>
                                </HBox>
                            </Tab>
                            <Tab text="Tự Động Đấu Giá">
                                <VBox spacing="12" style="-fx-padding: 18 0 5 0;">
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <TextField fx:id="txtMaxBid" promptText="Mức giá tối đa (Max)" HBox.hgrow="ALWAYS"
                                                   style="-fx-background-radius: 8; -fx-padding: 11; -fx-border-color: #cbd5e1; -fx-background-color: #f8fafc; -fx-font-size: 13px;"/>
                                        <TextField fx:id="txtIncrement" promptText="Bước giá (+)" prefWidth="130"
                                                   style="-fx-background-radius: 8; -fx-padding: 11; -fx-border-color: #cbd5e1; -fx-background-color: #f8fafc; -fx-font-size: 13px;"/>
                                        <Button fx:id="btnToggleAutoBid" text="Kích Hoạt" onAction="#handleAutoBid" prefHeight="40"
                                                style="-fx-background-color: #ea580c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 18; -fx-cursor: hand;"/>
                                    </HBox>
                                </VBox>
                            </Tab>
                        </TabPane>
                        <Label fx:id="lblStatusMessage" text="" style="-fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">
                        <Label text="Biến động giá sản phẩm" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #0f172a;" />
                        <LineChart fx:id="priceChart" prefHeight="300" animated="false" createSymbols="false"
                                   style="-fx-chart-plot-background: transparent; -fx-vertical-grid-lines-visible: false; -fx-horizontal-grid-lines-visible: true;">
                            <xAxis>
                                <CategoryAxis fx:id="xAxisTimeline" side="BOTTOM" tickLabelsVisible="false" tickMarkVisible="false" label="" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="yAxisPrice" side="LEFT" autoRanging="true" tickLabelsVisible="true" minorTickVisible="true" label="" />
                            </yAxis>
                        </LineChart>
                    </VBox>
                </VBox>
            </ScrollPane>
        </GridPane>
    </VBox>
</HBox>