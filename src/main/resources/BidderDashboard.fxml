<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="AuctionSystem.controller.BidderDashboardController">

    <top>
        <Label text="BIDDER DASHBOARD"
               style="-fx-font-size: 20px; -fx-padding: 10;"/>
    </top>

    <center>
        <VBox spacing="10" alignment="CENTER">

            <TableView fx:id="itemTable" prefHeight="250" prefWidth="800">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="100"/>
                    <TableColumn fx:id="colName" text="Tên Sản Phẩm" prefWidth="150"/>
                    <TableColumn fx:id="colPrice" text="Giá Hiện Tại" prefWidth="120"/>
                    <TableColumn fx:id="colHighestBidder" text="Người Dẫn Đầu" prefWidth="130"/>
                    <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="100"/>
                    <TableColumn fx:id="colTime" text="Thời Gian" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="txtBidPrice" promptText="Nhập giá"/>
                <Button text="Đặt giá" onAction="#handleBid"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>