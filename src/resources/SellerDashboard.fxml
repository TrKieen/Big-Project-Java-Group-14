<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.logincontroller.controller.SellerDashboardController"
            style="-fx-background-color: #f4f4f4;">

    <top>
        <Label text="QUẢN LÝ SẢN PHẨM ĐẤU GIÁ" textFill="#0050ee" BorderPane.alignment="CENTER">
            <font><Font name="System Bold" size="24.0" /></font>
            <padding><Insets top="20" bottom="20"/></padding>
        </Label>
    </top>

    <center>
        <TableView fx:id="itemTable">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="300" />
                <TableColumn fx:id="colPrice" text="Giá khởi điểm" prefWidth="200" />
                <TableColumn fx:id="colHighestPrice" text="Giá hiện tại cao nhất" prefWidth="200" />

                <TableColumn fx:id="colStartTime" text="Bắt đầu" prefWidth="150" />
                <TableColumn fx:id="colEndTime" text="Kết thúc" prefWidth="150" />
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <BorderPane.margin><Insets left="20" right="20" bottom="20"/></BorderPane.margin>

            <Label text="Nhập thông tin sản phẩm" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            <TextField fx:id="txtName" promptText="Tên sản phẩm" />
            <TextArea fx:id="txtDescription" promptText="Mô tả..." prefRowCount="3"/>
            <TextField fx:id="txtStartingPrice" promptText="Giá khởi điểm (VNĐ)" />
            <ComboBox fx:id="cbItemType" promptText="Loại sản phẩm" prefWidth="200"/>
            <TextField fx:id="txtExtraInfo" promptText="Thông số phụ (Tác giả, Bảo hành...)" />
            <HBox spacing="5" alignment="CENTER_LEFT">
                <DatePicker fx:id="dpStartTime" promptText="Ngày bắt đầu" prefWidth="130"/>
                <TextField fx:id="txtStartTime" promptText="Giờ:Phút:Giây" prefWidth="130"/>
            </HBox>

            <HBox spacing="5" alignment="CENTER_LEFT">
                <DatePicker fx:id="dpEndTime" promptText="Ngày kết thúc" prefWidth="130"/>
                <TextField fx:id="txtEndTime" promptText="Giờ:Phút:Giây" prefWidth="130"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Thêm" onAction="#handleAddItem" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Cập nhật" onAction="#handleUpdateItem" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Xóa" onAction="#handleDeleteItem" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </right>
</BorderPane>